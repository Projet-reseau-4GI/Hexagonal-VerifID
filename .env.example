# ─────────────────────────────────────────────────────────────────────────────
# VerifID — Variables d'environnement (EXEMPLE)
# Copier ce fichier en .env et renseigner les valeurs réelles.
# NE JAMAIS committer le fichier .env avec de vrais secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de données PostgreSQL ────────────────────────────────────────────────
# Hôte PostgreSQL (service Docker IWM partagé ou PostgreSQL dédié)
DB_HOST=iwm-postgres
DB_PORT=5432
VERIFID_DB_NAME=verifid
IWM_DB_USER=iwm
IWM_DB_PASSWORD=changeme_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
# Utiliser verifid-redis (local docker-compose) ou iwm-redis (IWM partagé)
REDIS_HOST=verifid-redis
REDIS_PORT=6379

# ── KSM Kernel Layer ─────────────────────────────────────────────────────────
KERNEL_BASE_URL=http://iwm-app:8080
KERNEL_CLIENT_ID=verifid-backend
# Clé API secrète de l'application cliente KYC dans le Kernel
KERNEL_API_KEY=your_kernel_api_key_here

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=iwm-kafka:29092
KAFKA_CONSUMER_GROUP=verifid-group

# ── OCR Parsing API ───────────────────────────────────────────────────────────
PARSING_API_URL=https://your-ocr-api.example.com/layout-parsing
PARSING_API_TOKEN=your_ocr_api_token_here

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-lite-latest

# ── Email transactionnel (Brevo) ──────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@votre-domaine.com
BREVO_SENDER_NAME=VerifID

# ── Sécurité ─────────────────────────────────────────────────────────────────
# JWT_SECRET : minimum 32 caractères aléatoires (générer avec: openssl rand -base64 32)
JWT_SECRET=changeme_minimum_32_chars_random_secret_key_here
# ENCRYPTION_SECRET_KEY : clé AES-256 (exactement 32 chars)
ENCRYPTION_SECRET_KEY=changeme_exactly_32_chars_aes_key

# ── Rate limiting & quotas ────────────────────────────────────────────────────
# Nombre max de requêtes par seconde par API key
APP_RATE_LIMIT_PER_SECOND=10

# ── Déploiement ───────────────────────────────────────────────────────────────
# Hôte public pour Traefik (ex: 192.168.1.100.nip.io)
PUBLIC_HOST=localhost
# Image Docker à utiliser (ou laisser vide pour builder localement)
VERIFID_IMAGE=ghcr.io/savhel/hexagonal-verifid:latest

# ── Limites de fichiers (optionnel, valeurs par défaut) ──────────────────────
SPRING_WEBFLUX_MULTIPART_MAX_FILE_SIZE=50MB
SPRING_WEBFLUX_MULTIPART_MAX_REQUEST_SIZE=50MB
SPRING_CODEC_MAX_IN_MEMORY_SIZE=50MB
