# VerifID — déploiement sur l'infra iwm partagée. Copier en .env et compléter.

# =========================================================
# KERNEL CORE CONNECTION (RT-Comops KSM Kernel Layer)
# =========================================================
KERNEL_BASE_URL=http://localhost:8082
KERNEL_CLIENT_ID=verifid-backend
KERNEL_API_KEY=change-me-secret-clientapplication-kyc
KERNEL_SERVICE_CODE=KYC
KERNEL_JWT_RS256_ENABLED=false

# =========================================================
# PostgreSQL Database Configuration
# =========================================================
# Base partagée (mot de passe = celui du Postgres iwm, voir .env de la stack iwm)
DB_URL=r2dbc:postgresql://localhost:5432/postgres?sslMode=disable
DB_USERNAME=postgres
DB_PASSWORD=change-me-meme-mdp-que-iwm
VERIFID_DB_NAME=verifid
SPRING_SQL_INIT_MODE=always

# =========================================================
# Configuration Email (Brevo API)
# =========================================================
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=innovtech830@gmail.com
BREVO_SENDER_NAME=VerifID

# =========================================================
# Configuration de l'application
# =========================================================
APP_NAME=VerifID
APP_SUPPORT_EMAIL=support@network.com
APP_PASSWORD_RESET_CODE_LENGTH=6
APP_PASSWORD_RESET_EXPIRY_MINUTES=15
APP_PASSWORD_RESET_MAX_ATTEMPTS=3
APP_EMAIL_VERIFICATION_CODE_LENGTH=6
APP_EMAIL_VERIFICATION_EXPIRY_MINUTES=15

# =========================================================
# Security & Encryption
# =========================================================
# JWT Local (Legacy / Standalone)
JWT_SECRET=change-me-jwt-secret
# AES-256 Encryption Key
ENCRYPTION_SECRET_KEY=change-me-aes-256-key

# =========================================================
# Supabase Configuration
# =========================================================
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=Documents

# =========================================================
# External APIs
# =========================================================
# Parse Configuration
PARSING_API_URL=https://lcgfy76ct94esfka.aistudio-app.com/layout-parsing
PARSING_API_TOKEN=your_parsing_api_token

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={key}

# =========================================================
# Server & Deployment
# =========================================================
RENDER_EXTERNAL_URL=http://localhost:8080
VERIFID_PUBLIC_PORT=8080
PUBLIC_HOST=CHANGE_ME.nip.io

# =========================================================
# Logging & Metrics
# =========================================================
LOGGING_LEVEL_WEB=DEBUG
LOGGING_LEVEL_APP=DEBUG
REACTOR_NETTY_MAX_CONNECTIONS=100
REACTOR_NETTY_MAX_IDLE_TIME=20s

# =========================================================
# Swagger / OpenAPI
# =========================================================
SPRINGDOC_API_DOCS_PATH=/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html
SPRINGDOC_SWAGGER_UI_ENABLED=true

# =========================================================
# Actuator
# =========================================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# =========================================================
# Multipart / WebFlux limits
# =========================================================
SPRING_WEBFLUX_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_WEBFLUX_MULTIPART_MAX_REQUEST_SIZE=10MB
SPRING_CODEC_MAX_IN_MEMORY_SIZE=10MB
